{
  "rootPackageJson": "package.json",
  "packages": [
    "apps/admin",
    "apps/api",
    "apps/docs",
    "apps/mobile",
    "apps/web",
    "packages/auth",
    "packages/i18n",
    "packages/infra",
    "packages/ui"
  ],
  "changelogFile": "CHANGELOG.md",
  "conventionalCommits": true,
  "syncDependencies": true,
  "ignorePackages": [],
  "extensions": [
    {
      "name": "alternun-mobile-app-version-sync",
      "path": "./scripts/versioning/mobile-app-version-extension.cjs"
    }
  ],
  "branchAwareness": {
    "enabled": true,
    "defaultBranch": "master",
    "branches": {
      "master": {
        "versionFormat": "semantic",
        "tagFormat": "v{version}",
        "syncFiles": ["package.json"],
        "environment": "production",
        "bumpStrategy": "semantic"
      },
      "main": {
        "versionFormat": "semantic",
        "tagFormat": "v{version}",
        "syncFiles": ["package.json"],
        "environment": "production",
        "bumpStrategy": "semantic"
      },
      "develop": {
        "versionFormat": "semantic",
        "tagFormat": "v{version}",
        "syncFiles": ["package.json"],
        "environment": "development",
        "bumpStrategy": "semantic"
      },
      "feature/*": {
        "versionFormat": "feature",
        "tagFormat": "v{version}",
        "syncFiles": ["package.json"],
        "environment": "development",
        "bumpStrategy": "feature-branch"
      },
      "hotfix/*": {
        "versionFormat": "hotfix",
        "tagFormat": "v{version}",
        "syncFiles": ["package.json"],
        "environment": "development",
        "bumpStrategy": "hotfix"
      }
    }
  }
}
