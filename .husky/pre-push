#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Check versioning before push
npm run version:validate
npm run version:check-secrets

# Guard against empty changelog entries on tagged releases
npm run changelog:check

# Ensure REENTRY.md is in sync with reentry.status.json.
# Skip with: git push --no-validate-reentry  OR  SKIP_REENTRY_VALIDATION=true git push
bash scripts/validate-reentry-status.sh "$@"
