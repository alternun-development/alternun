#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Guard: ensure correct AWS account (info only, not enforced in pre-commit)
bash scripts/validate-aws-account.sh check

# Guard: prevent non-critical .md files in root (keep docs/ organized)
bash scripts/validate-root-docs.sh true

# Block accidental secret commits before linting.
pnpm -s version:check-secrets

if [ "${ALTERNUN_RELEASE_COMMIT:-false}" = "true" ]; then
  echo "Skipping lint-staged for autogenerated release commit."
else
  npx lint-staged
fi
