# Repo-wide local defaults

# Current delivery mode:
# - `on`: master/main is the working branch and must be mirrored into develop
# - `off`: use the traditional develop -> master promotion flow
ALTERNUN_TESTNET_MODE=on

# Versioning policy:
# always use the versioning scripts for version bumps and changelog updates.
# Do not edit version fields manually in package.json or CHANGELOG.md.
