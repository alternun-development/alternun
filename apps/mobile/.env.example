EXPO_PUBLIC_SUPABASE_URL=https://zv...upabase.co
EXPO_PUBLIC_SUPABASE_KEY=sb_publishable.....-sw_rRuHwcKy
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=
EXPO_PUBLIC_PRIMARY_OAUTH_PROVIDER=google
EXPO_PUBLIC_ENABLE_MOCK_WALLET_AUTH=false
EXPO_PUBLIC_ENABLE_WALLET_ONLY_AUTH=false

# Authentik OIDC (Google + Discord login without Supabase Auth vendor lock-in)
# Issuer URL — e.g. https://testnet.sso.alternun.co/application/o/<slug>/
# Deployed web builds can derive this from the live airs origin if omitted.
EXPO_PUBLIC_AUTHENTIK_ISSUER=
# OAuth2 client ID registered in Authentik (public client, no secret)
# Defaults to alternun-mobile if omitted in deployed web builds.
EXPO_PUBLIC_AUTHENTIK_CLIENT_ID=
# Redirect URI configured in Authentik. If omitted in deployed web builds,
# the shared auth helpers derive `https://<origin>/auth/callback`.
# Local browser origins win over stale loopback or testnet values so local
# web testing always returns to the active app origin.
EXPO_PUBLIC_AUTHENTIK_REDIRECT_URI=
# Login entry pattern: source jumps straight to Authentik; relay keeps the app as the visible entrypoint.
EXPO_PUBLIC_AUTHENTIK_LOGIN_ENTRY_MODE=source
# Social login backend mode:
# - authentik keeps Google/Discord on Authentik-first flows
# - hybrid is opt-in if you intentionally want Supabase fallback while iterating
# - supabase bypasses Authentik social login entirely
EXPO_PUBLIC_AUTHENTIK_SOCIAL_LOGIN_MODE=authentik
# Release-update mode for the shared worker/banner:
# - auto enables on non-loopback hosts and keeps localhost quiet
# - on forces the banner on everywhere
# - off disables the banner entirely
EXPO_PUBLIC_RELEASE_UPDATE_MODE=auto
# Optional JSON mapping of provider -> custom Authentik flow slug.
# Leave this empty unless you explicitly want a custom Authentik starter flow.
# Loopback hosts such as localhost and 127.0.0.1 still ignore custom flow slugs.
EXPO_PUBLIC_AUTHENTIK_PROVIDER_FLOW_SLUGS=
# Explicit opt-in for custom provider-flow slugs.
# Leave this false for the default direct source-login path.
EXPO_PUBLIC_AUTHENTIK_ALLOW_CUSTOM_PROVIDER_FLOW_SLUGS=false

# Optional: override landing video URLs for web (CDN). Falls back to bundled local assets when unset.
EXPO_PUBLIC_AIRS_VIDEO_EN_URL=
EXPO_PUBLIC_AIRS_VIDEO_ES_URL=
