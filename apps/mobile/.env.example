# Example env for target mobile

# Internal Better Auth base URL
AUTH_BETTER_AUTH_URL=http://localhost:8082/auth
# Internal auth exchange endpoint
AUTH_EXCHANGE_URL=http://localhost:8082/auth/exchange
# Runtime auth execution provider
AUTH_EXECUTION_PROVIDER=supabase
# Override English landing video URL
EXPO_PUBLIC_AIRS_VIDEO_EN_URL=
# Override Spanish landing video URL
EXPO_PUBLIC_AIRS_VIDEO_ES_URL=
# Public API base URL
EXPO_PUBLIC_API_URL=http://localhost:8082
# Public auth exchange endpoint
EXPO_PUBLIC_AUTH_EXCHANGE_URL=http://localhost:8082/auth/exchange
# Auth execution provider selector
EXPO_PUBLIC_AUTH_EXECUTION_PROVIDER=supabase
# Enable custom Authentik provider flow slugs
EXPO_PUBLIC_AUTHENTIK_ALLOW_CUSTOM_PROVIDER_FLOW_SLUGS=false
# Authentik client id
EXPO_PUBLIC_AUTHENTIK_CLIENT_ID=alternun-mobile
# Authentik issuer URL
EXPO_PUBLIC_AUTHENTIK_ISSUER=https://testnet.sso.alternun.co/application/o/alternun-mobile/
# Authentik login entry mode
EXPO_PUBLIC_AUTHENTIK_LOGIN_ENTRY_MODE=source
# Custom Authentik provider flow slugs
EXPO_PUBLIC_AUTHENTIK_PROVIDER_FLOW_SLUGS=
# Authentik redirect URI
EXPO_PUBLIC_AUTHENTIK_REDIRECT_URI=
# Authentik social-login mode
EXPO_PUBLIC_AUTHENTIK_SOCIAL_LOGIN_MODE=supabase
# Public Better Auth base URL
EXPO_PUBLIC_BETTER_AUTH_URL=http://localhost:8082/auth
# Enable mock wallet auth fallback
EXPO_PUBLIC_ENABLE_MOCK_WALLET_AUTH=false
# Enable social auth buttons in the mobile auth screen
EXPO_PUBLIC_ENABLE_SOCIAL_AUTH=true
# Allow wallet-only auth sessions
EXPO_PUBLIC_ENABLE_WALLET_ONLY_AUTH=false
# Default public OAuth provider
EXPO_PUBLIC_PRIMARY_OAUTH_PROVIDER=google
# Mobile release check interval
EXPO_PUBLIC_RELEASE_CHECK_INTERVAL_MS=60000
# Release update banner mode
EXPO_PUBLIC_RELEASE_UPDATE_MODE=off
