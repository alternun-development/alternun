PORT=8082
HOST=localhost

# Internal Better Auth dev service (`pnpm --filter @alternun/api run dev:better-auth`).
# The browser-facing URL stays on the API origin (`http://localhost:8082/auth`),
# and the API proxies `/auth/*` to this internal service.
# Copy these into `.env.better-auth` when you want dev:all to start the local
# Better Auth execution server on port 9083.
BETTER_AUTH_URL=http://localhost:9083
BETTER_AUTH_SECRET=
BETTER_AUTH_TRUSTED_ORIGINS=http://localhost:8081,http://127.0.0.1:8081

# Better Auth social login credentials for local execution testing.
GOOGLE_AUTH_CLIENT_ID=
GOOGLE_AUTH_CLIENT_SECRET=
DISCORD_AUTH_CLIENT_ID=
DISCORD_AUTH_CLIENT_SECRET=

# Optional OAuth proxy settings for preview/dev routing.
# Leave these unset for the direct local Better Auth flow.
# BETTER_AUTH_OAUTH_PROXY_ENABLED=false
# BETTER_AUTH_OAUTH_PROXY_CURRENT_URL=http://localhost:8081
# BETTER_AUTH_OAUTH_PROXY_PRODUCTION_URL=http://localhost:9083
# BETTER_AUTH_OAUTH_PROXY_SECRET=
# BETTER_AUTH_OAUTH_PROXY_MAX_AGE=60

# Supabase — used by the Authentik webhook to upsert users into public.users
SUPABASE_URL=https://<project-ref>.supabase.co
# Prefer service-role key; falls back to anon key (upsert_oidc_user is SECURITY DEFINER)
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
# PostgreSQL connection string for Better Auth database adapter
# Get from Supabase Dashboard → Settings → Database → Connection pooling (Session mode)
DATABASE_URL=postgresql://postgres.<project-ref>:[password]@[region].pooling.supabase.com:6543/postgres

# Authentik — issuer URL used as the `iss` claim when syncing users from the webhook
AUTHENTIK_ISSUER=https://<authentik-host>/application/o/alternun-mobile/

# Optional signing key used by /auth/exchange when issuing backend-owned JWTs.
AUTHENTIK_JWT_SIGNING_KEY=

# Fail closed when /auth/exchange must mint issuer-owned JWTs but the signing key is missing.
AUTH_EXCHANGE_REQUIRE_ISSUER_OWNED=false

# Shared secret that Authentik sends in X-Authentik-Webhook-Secret header.
# Must match userSyncWebhookSecret in the AWS integration config secret.
AUTHENTIK_WEBHOOK_SECRET=
