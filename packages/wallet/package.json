{
  "name": "@alternun/wallet",
  "version": "1.0.127",
  "description": "Non-custodial HD wallet utilities for Alternun mobile",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "pnpm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "@noble/hashes": "^1.2.0",
    "@scure/bip32": "^2.2.0",
    "@scure/btc-signer": "^2.2.0",
    "@solana/web3.js": "^1.98.0",
    "bip39": "^3.1.0",
    "bs58": "^5.0.0",
    "ed25519-hd-key": "^1.3.0",
    "viem": "^2.21.0"
  },
  "devDependencies": {
    "@types/node": "^20.1.3",
    "expo-secure-store": "^15.0.0",
    "typescript": "~5.9.2"
  },
  "peerDependencies": {
    "expo-secure-store": "*"
  },
  "peerDependenciesMeta": {
    "expo-secure-store": {
      "optional": true
    }
  }
}
