{
  "name": "@alternun/email-templates",
  "version": "1.0.3",
  "description": "Locale-aware email copy and Supabase auth template helpers",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "README.md",
    "scripts"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./locales/*": "./dist/locales/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "./build.sh",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "./build.sh && node --test test/*.test.cjs",
    "generate:supabase": "node scripts/generate-supabase-auth-templates.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.1.3",
    "typescript": "~5.9.2"
  }
}
