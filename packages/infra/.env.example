# AWS provider (v1)
INFRA_PROVIDER=aws
AWS_REGION=us-east-1

# Optional: also load repo root .env before this file
INFRA_LOAD_ROOT_ENV=true

# Local credential behavior:
# - force env credentials over local AWS profile config
# - fail fast if env credentials are missing
INFRA_FORCE_ENV_AWS_CREDENTIALS=true
INFRA_REQUIRE_ENV_AWS_CREDENTIALS=true

# Deployment guardrails (recommended to prevent wrong-account deploys)
INFRA_ENFORCE_AWS_ACCOUNT=true
INFRA_AWS_ACCOUNT_ID=123456789012
INFRA_REQUIRE_ROUTE53=true
# Optional but recommended. Route53 hosted zone id for INFRA_ROOT_DOMAIN.
# Example: Z123ABC456DEF
INFRA_ROUTE53_HOSTED_ZONE_ID=

# SST app identity
INFRA_APP_NAME=alternun-infra

# Core domain + pipeline metadata
INFRA_ROOT_DOMAIN=alternun.co
INFRA_PIPELINE_REPO=alternun-development/alternun
INFRA_PIPELINE_PREFIX=alternun
INFRA_PROJECT_TAG=alternun

# Optional local JSON config file (kept out of git)
# INFRA_CONFIG_PATH=./config/deployment.config.json

# Pipeline stages to reconcile on the production pipeline stack.
# Allowed: production,dev,mobile,identity-dev,identity-prod,dashboard-dev,dashboard-prod or none
# Legacy token "identity" maps to identity-dev.
INFRA_PIPELINES=production,dev,identity-dev,identity-prod,dashboard-dev,dashboard-prod
# Optional canonical set used by scripts/ensure-pipelines.sh. If unset, it falls back to INFRA_CONFIG_PATH
# pipeline config or the full managed set above.
INFRA_MANAGED_PIPELINES_CANONICAL=
# Safety guard: refuse production pipeline-stack deploys that would prune existing managed pipelines
# unless you explicitly opt in for a planned removal.
INFRA_ENFORCE_PIPELINE_DELETE_GUARD=true
INFRA_ALLOW_PIPELINE_DELETION=false
INFRA_PIPELINE_BRANCH_PROD=master
INFRA_PIPELINE_BRANCH_DEV=develop
INFRA_PIPELINE_BRANCH_MOBILE=mobile
INFRA_PIPELINE_BRANCH_IDENTITY_DEV=develop
INFRA_PIPELINE_BRANCH_IDENTITY_PROD=master
INFRA_PIPELINE_BRANCH_DASHBOARD_DEV=develop
INFRA_PIPELINE_BRANCH_DASHBOARD_PROD=master
# Legacy override (optional): used as fallback for identity-dev branch.
INFRA_PIPELINE_BRANCH_IDENTITY=
INFRA_PIPELINE_BRANCH_DASHBOARD=
INFRA_PIPELINE_COMPUTE_TYPE=BUILD_GENERAL1_MEDIUM
INFRA_PIPELINE_COMPUTE_TYPE_DEV=BUILD_GENERAL1_LARGE
INFRA_PIPELINE_TIMEOUT_MINUTES=30

# Reuse an existing CodeStar connection instead of creating one
INFRA_CODESTAR_CONNECTION_ARN=

# Expo web target app and domains
INFRA_EXPO_APP_PATH=../../apps/mobile
INFRA_EXPO_SUBDOMAIN=airs
INFRA_EXPO_DOMAIN_PRODUCTION=airs.alternun.co
INFRA_EXPO_DOMAIN_DEV=testnet.airs.alternun.co
INFRA_EXPO_DOMAIN_MOBILE=preview.airs.alternun.co

# Set to false to deploy without Route53-managed custom domains (uses default CloudFront URL)
INFRA_EXPO_ENABLE_CUSTOM_DOMAIN=true
INFRA_REQUIRE_EXPO_PUBLIC_AUTH=true

# Required Expo web auth variables for deployed environments
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=

# Optional wallet/auth toggles
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=
EXPO_PUBLIC_WALLETCONNECT_CHAIN_ID=1
EXPO_PUBLIC_ENABLE_MOCK_WALLET_AUTH=false
EXPO_PUBLIC_ENABLE_WALLET_ONLY_AUTH=false

# Redirect controls (dev stage)
# Redirect airs.alternun.co -> testnet.airs.alternun.co when deploying stage=dev
INFRA_REDIRECT_AIRS_TO_DEV=true
INFRA_REDIRECT_AIRS_TO_DEV_SOURCE=airs.alternun.co
# Optional certificate for INFRA_REDIRECT_AIRS_TO_DEV_SOURCE domain
INFRA_REDIRECT_AIRS_TO_DEV_CERT_ARN=
# Redirect dev.airs.alternun.co -> testnet.airs.alternun.co when deploying stage=dev
INFRA_REDIRECT_DEV_TO_TESTNET=true
INFRA_REDIRECT_DEV_TO_TESTNET_SOURCE=dev.airs.alternun.co
# Optional certificate for INFRA_REDIRECT_DEV_TO_TESTNET source domain
INFRA_REDIRECT_DEV_TO_TESTNET_CERT_ARN=
# Auto-clean ACM validation CNAME records (_*.domain) when DNS auto-remove is enabled.
INFRA_REMOVE_ACM_VALIDATION_CNAME=true
# Fail fast when managed ACM certificate creation would collide with existing Route53 validation CNAME records.
INFRA_FAIL_ON_MANAGED_CERT_CNAME_CONFLICT=true
# Redirect alternun.co -> alternun.io when deploying stage=dev
INFRA_REDIRECT_ROOT_DOMAIN=true
INFRA_REDIRECT_ROOT_TARGET=alternun.io
# Optional certificate for INFRA_REDIRECT_ROOT_DOMAIN source domain
INFRA_REDIRECT_ROOT_CERT_ARN=

# Optional ACM certificates (leave empty to let SST create/manage)
INFRA_EXPO_CERT_ARN_PRODUCTION=
INFRA_EXPO_CERT_ARN_DEV=
INFRA_EXPO_CERT_ARN_MOBILE=

# Identity infrastructure (disabled until Authentik deployment is needed)
# Secret names are stage-scoped automatically at create time.
INFRA_IDENTITY_ENABLED=false
# Keep identity provisioning isolated to identity-dev/identity-prod stacks.
# Set false only if you intentionally want identity resources inside app stacks (dev/production/mobile).
INFRA_IDENTITY_DEDICATED_STACKS_ONLY=true
# Optional stage filter for identity deployment.
# Empty = all stages. Example: dev or dev,mobile
INFRA_IDENTITY_ENABLED_STAGES=
INFRA_IDENTITY_DOMAIN_PRODUCTION=auth.alternun.co
INFRA_IDENTITY_DOMAIN_DEV=testnet.auth.alternun.co
INFRA_IDENTITY_DOMAIN_MOBILE=preview.auth.alternun.co
# Database mode:
# - ec2: PostgreSQL runs on the same EC2 host as Authentik (optional low-cost mode)
# - rds: dedicated managed PostgreSQL in RDS (default for current dev/prod pipelines)
INFRA_IDENTITY_DATABASE_MODE=rds
INFRA_IDENTITY_EC2_INSTANCE_TYPE=t3.small
INFRA_IDENTITY_EC2_VOLUME_SIZE_GIB=20
INFRA_IDENTITY_RDS_ENGINE_VERSION=16
INFRA_IDENTITY_RDS_INSTANCE_TYPE=db.t4g.micro
INFRA_IDENTITY_RDS_STORAGE_GIB=20
INFRA_IDENTITY_RDS_MULTI_AZ=false
INFRA_IDENTITY_RDS_PUBLIC_ACCESS=false
INFRA_IDENTITY_RDS_BACKUP_RETENTION_DAYS=7
INFRA_IDENTITY_RDS_PERFORMANCE_INSIGHTS=false
INFRA_IDENTITY_RDS_ENHANCED_MONITORING=false
INFRA_IDENTITY_EMAIL_PROVIDER=ses
# Must be calendar-version and >= 2025.10 (Redisless Authentik baseline)
INFRA_IDENTITY_AUTHENTIK_IMAGE_TAG=2026.2
INFRA_IDENTITY_JWT_AUDIENCE=alternun-app
INFRA_IDENTITY_JWT_ROLE_CLAIM=role
INFRA_IDENTITY_JWT_ROLES_CLAIM=alternun_roles
INFRA_IDENTITY_JWT_ACCESS_TOKEN_TTL_MINUTES=15
# Optional: fallbacks are GOOGLE_AUTH_CLIENT_ID / GOOGLE_AUTH_CLIENT_SECRET (or GOOGLEA_AUTH_CLIENT_SECRET)
INFRA_IDENTITY_GOOGLE_AUTH_CLIENT_ID=
INFRA_IDENTITY_GOOGLE_AUTH_CLIENT_SECRET=
INFRA_IDENTITY_GOOGLE_SOURCE_NAME=Google
INFRA_IDENTITY_GOOGLE_SOURCE_SLUG=google
# Optional: fallbacks are SUPABASE_PROJECT_REF / SUPABASE_ACCESS_TOKEN
INFRA_IDENTITY_SUPABASE_PROJECT_REF=
INFRA_IDENTITY_SUPABASE_MANAGEMENT_ACCESS_TOKEN=
INFRA_IDENTITY_SUPABASE_OIDC_CLIENT_ID=alternun-supabase
INFRA_IDENTITY_SUPABASE_PROVIDER_NAME=Alternun Supabase OIDC
INFRA_IDENTITY_SUPABASE_APPLICATION_SLUG=alternun-supabase
INFRA_IDENTITY_SUPABASE_APPLICATION_NAME=Alternun Supabase
INFRA_IDENTITY_SUPABASE_SYNC_CONFIG=true
INFRA_IDENTITY_BOOTSTRAP_ADMIN_USERNAME=akadmin
INFRA_IDENTITY_BOOTSTRAP_ADMIN_EMAIL=admin@alternun.co
INFRA_IDENTITY_BOOTSTRAP_ADMIN_NAME=authentik Default Admin
# Optional override. Leave empty to persist an auto-generated stage-scoped password in integration secret.
INFRA_IDENTITY_BOOTSTRAP_ADMIN_PASSWORD=
INFRA_IDENTITY_BOOTSTRAP_ADMIN_GROUP=authentik Admins
INFRA_IDENTITY_DEFAULT_APPLICATION_ENABLED=true
INFRA_IDENTITY_DEFAULT_APPLICATION_NAME=Alternun Internal
INFRA_IDENTITY_DEFAULT_APPLICATION_SLUG=alternun-internal
INFRA_IDENTITY_DEFAULT_APPLICATION_GROUP=Alternun
# Optional; if empty, bootstrap uses https://<identity-domain>/if/user/#/library
INFRA_IDENTITY_DEFAULT_APPLICATION_LAUNCH_URL=
INFRA_IDENTITY_DEFAULT_APPLICATION_OPEN_IN_NEW_TAB=false
INFRA_IDENTITY_DEFAULT_APPLICATION_PUBLISHER=Alternun
INFRA_IDENTITY_DEFAULT_APPLICATION_DESCRIPTION=Alternun internal access
INFRA_IDENTITY_DEFAULT_APPLICATION_POLICY_ENGINE_MODE=any
INFRA_IDENTITY_SECRET_AUTHENTIK_KEY_NAME=alternun-infra/identity/authentik-secret-key
INFRA_IDENTITY_SECRET_DB_CREDENTIALS_NAME=alternun-infra/identity/database-credentials
INFRA_IDENTITY_SECRET_SMTP_CREDENTIALS_NAME=alternun-infra/identity/smtp-credentials
INFRA_IDENTITY_SECRET_JWT_SIGNING_KEY_NAME=alternun-infra/identity/jwt-signing-key
INFRA_IDENTITY_SECRET_INTEGRATION_CONFIG_NAME=alternun-infra/identity/integration-config

# Backend API infrastructure (disabled until NestJS API deployment is needed)
INFRA_ENABLE_BACKEND_API=false
# Keep backend provisioning isolated to api-dev/api-prod stacks.
# Set false only if you intentionally want backend resources inside app stacks (dev/production/mobile).
INFRA_BACKEND_API_DEDICATED_STACKS_ONLY=true
# Optional stage filter for backend API deployment.
# Empty = all stages. Example: dev or dev,production
INFRA_BACKEND_API_ENABLED_STAGES=
INFRA_BACKEND_API_APP_PATH=../../apps/api
INFRA_BACKEND_API_BUILD_COMMAND=pnpm --filter @alternun/api run build
INFRA_BACKEND_API_BUILD_OUTPUT=dist-lambda
INFRA_BACKEND_API_ENABLE_CUSTOM_DOMAIN=true
INFRA_BACKEND_API_DOMAIN_PRODUCTION=api.alternun.co
INFRA_BACKEND_API_DOMAIN_DEV=testnet.api.alternun.co
INFRA_BACKEND_API_DOMAIN_MOBILE=preview.api.alternun.co
INFRA_BACKEND_API_CERT_ARN_PRODUCTION=
INFRA_BACKEND_API_CERT_ARN_DEV=
INFRA_BACKEND_API_CERT_ARN_MOBILE=
INFRA_BACKEND_API_MEMORY_SIZE=1024
INFRA_BACKEND_API_TIMEOUT_SECONDS=30
INFRA_BACKEND_API_ARCHITECTURE=arm64
INFRA_BACKEND_API_LOG_RETENTION_DAYS=14
INFRA_BACKEND_API_AUTHENTIK_AUDIENCE=alternun-app
# Optional overrides. If empty, the deploy infers testnet/auth/preview issuers from INFRA_ROOT_DOMAIN.
INFRA_BACKEND_API_AUTHENTIK_ISSUER=
INFRA_BACKEND_API_AUTHENTIK_JWKS_URL=
# Optional runtime database connection string passed to the Lambda function as DATABASE_URL.
INFRA_BACKEND_API_DATABASE_URL=

# Admin site infrastructure (disabled until Refine admin deployment is needed)
INFRA_ENABLE_ADMIN_SITE=false
# Keep admin provisioning isolated to admin-dev/admin-prod stacks.
# Set false only if you intentionally want the admin SPA inside app stacks (dev/production/mobile).
INFRA_ADMIN_DEDICATED_STACKS_ONLY=true
# Optional stage filter for admin site deployment.
# Empty = all stages. Example: dev or dev,production
INFRA_ADMIN_ENABLED_STAGES=
INFRA_ADMIN_APP_PATH=../../apps/admin
INFRA_ADMIN_BUILD_COMMAND=pnpm --filter @alternun/admin run build
INFRA_ADMIN_BUILD_OUTPUT=dist
INFRA_ADMIN_ENABLE_CUSTOM_DOMAIN=true
INFRA_ADMIN_DOMAIN_PRODUCTION=admin.alternun.co
INFRA_ADMIN_DOMAIN_DEV=testnet.admin.alternun.co
INFRA_ADMIN_DOMAIN_MOBILE=preview.admin.alternun.co
INFRA_ADMIN_CERT_ARN_PRODUCTION=
INFRA_ADMIN_CERT_ARN_DEV=
INFRA_ADMIN_CERT_ARN_MOBILE=
INFRA_ADMIN_API_URL_PRODUCTION=https://api.alternun.co
INFRA_ADMIN_API_URL_DEV=https://testnet.api.alternun.co
INFRA_ADMIN_API_URL_MOBILE=https://preview.api.alternun.co
INFRA_ADMIN_AUTH_ISSUER_PRODUCTION=https://auth.alternun.co
INFRA_ADMIN_AUTH_ISSUER_DEV=https://testnet.auth.alternun.co
INFRA_ADMIN_AUTH_ISSUER_MOBILE=https://preview.auth.alternun.co
INFRA_ADMIN_AUTH_CLIENT_ID=alternun-admin
INFRA_ADMIN_AUTH_AUDIENCE=alternun-app

# Optional Expo build overrides
INFRA_EXPO_BUILD_COMMAND=npx expo export -p web
INFRA_EXPO_BUILD_OUTPUT=dist
# Set false only on dedicated identity/backend/admin stacks (identity-dev / identity-prod / api-dev / api-prod / admin-dev / admin-prod).
INFRA_ENABLE_EXPO_SITE=true
# Optional speed toggles for dedicated backend/identity pipelines
INFRA_ENABLE_SECRET_SYNC=true
INFRA_ENABLE_PREDEPLOY_CHECKS=true
INFRA_ENABLE_SST_DIFF=false

# Recovery-only cleanup. Keep disabled for normal deploys because it forces extra
# CloudFront alias churn and slows the build considerably.
INFRA_ENABLE_ALIAS_CLEANUP=false
