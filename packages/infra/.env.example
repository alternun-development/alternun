# AWS provider (v1)
INFRA_PROVIDER=aws
AWS_REGION=us-east-1

# Optional: also load repo root .env before this file
INFRA_LOAD_ROOT_ENV=true

# Local credential behavior:
# - force env credentials over local AWS profile config
# - fail fast if env credentials are missing
INFRA_FORCE_ENV_AWS_CREDENTIALS=true
INFRA_REQUIRE_ENV_AWS_CREDENTIALS=true

# Deployment guardrails (recommended to prevent wrong-account deploys)
INFRA_ENFORCE_AWS_ACCOUNT=true
INFRA_AWS_ACCOUNT_ID=123456789012
INFRA_REQUIRE_ROUTE53=true
# Optional but recommended. Route53 hosted zone id for INFRA_ROOT_DOMAIN.
# Example: Z123ABC456DEF
INFRA_ROUTE53_HOSTED_ZONE_ID=

# SST app identity
INFRA_APP_NAME=alternun-infra

# Core domain + pipeline metadata
INFRA_ROOT_DOMAIN=alternun.co
INFRA_PIPELINE_REPO=alternun-development/alternun
INFRA_PIPELINE_PREFIX=alternun
INFRA_PROJECT_TAG=alternun

# Optional local JSON config file (kept out of git)
# INFRA_CONFIG_PATH=./config/deployment.config.json

# Pipeline stages to create when deploying production stage
# Allowed: production,dev,mobile or none
INFRA_PIPELINES=production,dev
INFRA_PIPELINE_BRANCH_PROD=master
INFRA_PIPELINE_BRANCH_DEV=develop
INFRA_PIPELINE_BRANCH_MOBILE=mobile

# Reuse an existing CodeStar connection instead of creating one
INFRA_CODESTAR_CONNECTION_ARN=

# Expo web target app and domains
INFRA_EXPO_APP_PATH=../../apps/mobile
INFRA_EXPO_SUBDOMAIN=airs
INFRA_EXPO_DOMAIN_PRODUCTION=airs.alternun.co
INFRA_EXPO_DOMAIN_DEV=testnet.airs.alternun.co
INFRA_EXPO_DOMAIN_MOBILE=preview.airs.alternun.co

# Set to false to deploy without Route53-managed custom domains (uses default CloudFront URL)
INFRA_EXPO_ENABLE_CUSTOM_DOMAIN=true
INFRA_REQUIRE_EXPO_PUBLIC_AUTH=true

# Required Expo web auth variables for deployed environments
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_KEY=

# Optional wallet/auth toggles
EXPO_PUBLIC_WALLETCONNECT_PROJECT_ID=
EXPO_PUBLIC_WALLETCONNECT_CHAIN_ID=1
EXPO_PUBLIC_ENABLE_MOCK_WALLET_AUTH=false
EXPO_PUBLIC_ENABLE_WALLET_ONLY_AUTH=false

# Redirect controls (dev stage)
# Redirect airs.alternun.co -> testnet.airs.alternun.co when deploying stage=dev
INFRA_REDIRECT_AIRS_TO_DEV=true
INFRA_REDIRECT_AIRS_TO_DEV_SOURCE=airs.alternun.co
# Optional certificate for INFRA_REDIRECT_AIRS_TO_DEV_SOURCE domain
INFRA_REDIRECT_AIRS_TO_DEV_CERT_ARN=
# Redirect dev.airs.alternun.co -> testnet.airs.alternun.co when deploying stage=dev
INFRA_REDIRECT_DEV_TO_TESTNET=true
INFRA_REDIRECT_DEV_TO_TESTNET_SOURCE=dev.airs.alternun.co
# Optional certificate for INFRA_REDIRECT_DEV_TO_TESTNET source domain
INFRA_REDIRECT_DEV_TO_TESTNET_CERT_ARN=
# Auto-clean ACM validation CNAME records (_*.domain) when DNS auto-remove is enabled.
INFRA_REMOVE_ACM_VALIDATION_CNAME=true
# Fail fast when managed ACM certificate creation would collide with existing Route53 validation CNAME records.
INFRA_FAIL_ON_MANAGED_CERT_CNAME_CONFLICT=true
# Redirect alternun.co -> alternun.io when deploying stage=dev
INFRA_REDIRECT_ROOT_DOMAIN=true
INFRA_REDIRECT_ROOT_TARGET=alternun.io
# Optional certificate for INFRA_REDIRECT_ROOT_DOMAIN source domain
INFRA_REDIRECT_ROOT_CERT_ARN=

# Optional ACM certificates (leave empty to let SST create/manage)
INFRA_EXPO_CERT_ARN_PRODUCTION=
INFRA_EXPO_CERT_ARN_DEV=
INFRA_EXPO_CERT_ARN_MOBILE=

# Optional Expo build overrides
INFRA_EXPO_BUILD_COMMAND=npx expo export -p web
INFRA_EXPO_BUILD_OUTPUT=dist

# Recovery-only cleanup. Keep disabled for normal deploys because it forces extra
# CloudFront alias churn and slows the build considerably.
INFRA_ENABLE_ALIAS_CLEANUP=false
