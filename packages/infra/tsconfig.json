{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "*.ts",
    "config/**/*.ts",
    "modules/**/*.ts",
    "sst-env.d.ts",
    ".sst/platform/config.d.ts"
  ]
}
