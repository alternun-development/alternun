{
  "appName": "alternun-infra",
  "rootDomain": "alternun.co",
  "pipeline": {
    "repo": "alternun-development/alternun",
    "prefix": "alternun",
    "projectTag": "alternun",
    "pipelines": "production,dev,identity-dev,identity-prod,dashboard-dev,dashboard-prod",
    "branchProd": "master",
    "branchDev": "develop",
    "branchIdentityDev": "develop",
    "branchIdentityProd": "master",
    "branchDashboardDev": "develop",
    "branchDashboardProd": "master"
  },
  "expo": {
    "appPath": "../../apps/mobile",
    "subdomain": "airs",
    "domains": {
      "production": "airs.alternun.co",
      "dev": "testnet.airs.alternun.co",
      "mobile": "preview.airs.alternun.co"
    },
    "certArns": {
      "production": "",
      "dev": "",
      "mobile": ""
    },
    "build": {
      "command": "npx expo export -p web",
      "output": "dist"
    },
    "publicEnv": {
      "authentikLoginEntryMode": "relay",
      "authentikSocialLoginMode": "authentik"
    }
  },
  "redirects": {
    "enableAirsToDev": true,
    "airsToDevSourceDomain": "airs.alternun.co",
    "enableDevToTestnet": true,
    "devToTestnetSourceDomain": "dev.airs.alternun.co",
    "enableRootDomainRedirect": true,
    "rootDomainTarget": "alternun.io",
    "certArns": {
      "airsToDev": "",
      "rootDomain": "",
      "devToTestnet": ""
    }
  },
  "backend": {
    "api": {
      "enabled": false,
      "appPath": "../../apps/api",
      "buildOutput": "dist-lambda",
      "buildCommand": "pnpm --filter @alternun/api run build",
      "enableCustomDomain": true,
      "domains": {
        "production": "api.alternun.co",
        "dev": "testnet.api.alternun.co",
        "mobile": "preview.api.alternun.co"
      },
      "certArns": {
        "production": "",
        "dev": "",
        "mobile": ""
      },
      "lambda": {
        "architecture": "arm64",
        "logRetentionDays": 14,
        "memorySize": 1024,
        "timeoutSeconds": 30
      },
      "auth": {
        "audience": "alternun-app",
        "issuer": "",
        "jwksUrl": ""
      },
      "environment": {
        "DATABASE_URL": "",
        "DECAP_PUBLIC_BASE_URL": "https://api.alternun.co",
        "DECAP_ALLOWED_ORIGINS": "https://docs.alternun.io,https://alternun-development.github.io,http://127.0.0.1:8083,http://localhost:8083",
        "DECAP_GITHUB_OAUTH_CLIENT_ID": "",
        "DECAP_GITHUB_OAUTH_CLIENT_SECRET": "",
        "DECAP_GITHUB_OAUTH_REPO_PRIVATE": "false",
        "DECAP_GITHUB_OAUTH_SCOPE": "",
        "DECAP_OAUTH_STATE_SECRET": ""
      }
    }
  },
  "admin": {
    "enabled": false,
    "appPath": "../../apps/admin",
    "buildOutput": "dist",
    "buildCommand": "pnpm --filter @alternun/admin run build",
    "enableCustomDomain": true,
    "domains": {
      "production": "admin.alternun.co",
      "dev": "testnet.admin.alternun.co",
      "mobile": "preview.admin.alternun.co"
    },
    "certArns": {
      "production": "",
      "dev": "",
      "mobile": ""
    },
    "apiUrls": {
      "production": "https://api.alternun.co",
      "dev": "https://testnet.api.alternun.co",
      "mobile": "https://preview.api.alternun.co"
    },
    "authIssuers": {
      "production": "https://sso.alternun.co/application/o/alternun-admin/",
      "dev": "https://testnet.sso.alternun.co/application/o/alternun-admin/",
      "mobile": "https://preview.sso.alternun.co/application/o/alternun-admin/"
    },
    "authClientId": "alternun-admin",
    "authAudience": "alternun-app",
    "allowedEmailDomain": "alternun.io",
    "environment": {}
  },
  "identity": {
    "enabled": false,
    "domains": {
      "production": "sso.alternun.co",
      "dev": "testnet.sso.alternun.co",
      "mobile": "preview.sso.alternun.co"
    },
    "ingress": {
      "modes": {
        "production": "alb",
        "dev": "instance",
        "mobile": "instance"
      },
      "alb": {
        "certificateArn": "",
        "healthCheckMatcher": "200-399",
        "healthCheckPath": "/",
        "idleTimeoutSeconds": 60
      }
    },
    "tls": {
      "modes": {
        "production": "alb-acm",
        "dev": "acme-route53-dns-01",
        "mobile": "acme-route53-dns-01"
      },
      "acmeEmail": "identity-admin@alternun.co",
      "route53HostedZoneId": "",
      "acmeBackup": {
        "enabled": true,
        "prefix": "state"
      }
    },
    "ec2": {
      "instanceType": "t3.small",
      "volumeSizeGiB": 20
    },
    "rds": {
      "engineVersion": "16",
      "instanceType": "db.t4g.micro",
      "storageGiB": 20,
      "multiAz": false,
      "publicAccess": false,
      "backupRetentionDays": 7,
      "performanceInsights": false,
      "enhancedMonitoring": false
    },
    "emailProvider": "ses",
    "authentikImageTag": "2026.2",
    "jwt": {
      "audience": "alternun-app",
      "roleClaim": "role",
      "rolesClaim": "alternun_roles",
      "accessTokenTtlMinutes": 15
    },
    "integration": {
      "google": {
        "clientId": "",
        "clientSecret": "",
        "sourceName": "Google",
        "sourceSlug": "google",
        "loginFlowSlug": ""
      },
      "supabase": {
        "applicationName": "Alternun Supabase",
        "applicationSlug": "alternun-supabase",
        "managementAccessToken": "",
        "oidcClientId": "alternun-supabase",
        "projectRef": "",
        "providerName": "Alternun Supabase OIDC",
        "syncConfig": true
      },
      "adminOidc": {
        "applicationName": "Alternun Admin",
        "applicationSlug": "alternun-admin",
        "providerName": "Alternun Admin OIDC",
        "clientId": "alternun-admin",
        "localDevUrl": "http://localhost:4173"
      },
      "docsCmsOidc": {
        "applicationName": "Alternun Docs CMS",
        "applicationSlug": "alternun-docs-cms",
        "providerName": "Alternun Docs CMS OIDC",
        "clientId": "alternun-docs-cms",
        "siteUrl": "https://docs.alternun.io",
        "localDevUrl": "http://127.0.0.1:8083",
        "allowedGroups": ["authentik Admins", "Alternun Dashboard Admins", "Alternun Docs Editors"]
      },
      "bootstrap": {
        "admin": {
          "username": "akadmin",
          "email": "admin@alternun.co",
          "name": "authentik Default Admin",
          "password": "",
          "group": "authentik Admins"
        },
        "defaultApplication": {
          "enabled": true,
          "name": "Alternun Internal",
          "slug": "alternun-internal",
          "group": "Alternun",
          "launchUrl": "",
          "openInNewTab": false,
          "publisher": "Alternun",
          "description": "Alternun internal access",
          "policyEngineMode": "any"
        }
      }
    },
    "secrets": {
      "authentikSecretKeyName": "alternun-infra/identity/authentik-secret-key",
      "databaseCredentialsSecretName": "alternun-infra/identity/database-credentials",
      "smtpCredentialsSecretName": "alternun-infra/identity/smtp-credentials",
      "jwtSigningKeySecretName": "alternun-infra/identity/jwt-signing-key",
      "integrationConfigSecretName": "alternun-infra/identity/integration-config"
    }
  }
}
