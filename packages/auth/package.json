{
  "name": "@alternun/auth",
  "version": "1.0.149",
  "description": "Alternun auth wrapper package built on top of @edcalderon/auth",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./facade": {
      "types": "./dist/facade/createAuthFacade.d.ts",
      "default": "./dist/facade/createAuthFacade.js"
    },
    "./mobile/AppAuthProvider": {
      "types": "./dist/mobile/AppAuthProvider.d.ts",
      "default": "./dist/mobile/AppAuthProvider.js"
    },
    "./mobile/authentikClient": {
      "types": "./dist/mobile/authentikClient.d.ts",
      "default": "./dist/mobile/authentikClient.js"
    },
    "./mobile/authEntry": {
      "types": "./dist/mobile/authEntry.d.ts",
      "default": "./dist/mobile/authEntry.js"
    },
    "./mobile/runtimeSignIn": {
      "types": "./dist/mobile/runtimeSignIn.d.ts",
      "default": "./dist/mobile/runtimeSignIn.js"
    }
  },
  "scripts": {
    "build": "./build.sh",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "test": "pnpm run build && node --loader ./scripts/node-extension-loader.mjs --test test/*.test.js",
    "type-check": "tsc --noEmit",
    "ses:bootstrap": "node infra/ses/scripts/01-bootstrap-identity.cjs",
    "ses:route53": "node infra/ses/scripts/02-apply-route53.cjs",
    "ses:smtp": "node infra/ses/scripts/03-generate-smtp-config.cjs",
    "ses:supabase": "node infra/ses/scripts/04-sync-supabase-smtp.cjs",
    "ses:status": "node infra/ses/scripts/05-status-report.cjs",
    "ses:migrate": "pnpm run ses:bootstrap && pnpm run ses:smtp && pnpm run ses:supabase && pnpm run ses:status",
    "email:generate": "node infra/email/scripts/01-generate-smtp-config.cjs",
    "email:supabase": "node infra/email/scripts/02-sync-supabase-smtp.cjs",
    "email:status": "node infra/email/scripts/03-status-report.cjs",
    "email:templates:generate": "node ../email-templates/scripts/generate-supabase-auth-templates.cjs",
    "email:templates:supabase": "node infra/email/scripts/04-sync-supabase-templates.cjs",
    "email:templates:apply": "pnpm run email:templates:generate && pnpm run email:templates:supabase",
    "email:apply": "pnpm run email:generate && pnpm run email:supabase && pnpm run email:status",
    "email:postmark": "EMAIL_SMTP_PROVIDER=postmark pnpm run email:apply",
    "email:ses": "EMAIL_SMTP_PROVIDER=ses pnpm run email:apply"
  },
  "dependencies": {
    "@edcalderon/auth": "1.4.2",
    "better-auth": "^1.6.3",
    "@supabase/supabase-js": "^2.98.0",
    "zod": "^3.24.2"
  },
  "peerDependencies": {
    "react": ">=18.2.0"
  },
  "devDependencies": {
    "@aws-sdk/client-route-53": "^3.940.0",
    "@aws-sdk/client-sesv2": "^3.940.0",
    "@types/node": "^20.1.3",
    "@types/react": "^19.1.17",
    "react": "19.1.0",
    "typescript": "~5.9.2"
  }
}
