{
  "name": "@alternun/i18n",
  "version": "1.0.63",
  "description": "Shared translation catalogs and locale helpers for Alternun apps",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "react-native": "src/index.ts",
  "source": "src/index.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./catalogs/*": "./dist/catalogs/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "./build.sh",
    "dev": "tsc -w",
    "clean": "rm -rf dist",
    "type-check": "tsc --noEmit",
    "test": "./build.sh && node test/runtime.test.cjs"
  },
  "devDependencies": {
    "@types/node": "^20.1.3",
    "typescript": "~5.9.2"
  }
}
